{
  "name": "ts-boilerplate",
  "description": "A simple TypeScript boilerplate with Bun and Biome",
  "author": {
    "name": "Aldin Čamdžić",
    "email": "acamdzic0@proton.me"
  },
  "license": "CC BY-NC 4.0",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "biome": "biome check --write --unsafe"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.7.2"
  }
}
